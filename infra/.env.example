# Copy to .env.local at the relevant package and fill in.

# Database
DATABASE_URL=postgresql+psycopg://tenjin:tenjin@localhost:5432/tenjin

# Redis (queue + pubsub)
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Source credentials (optional — adapters degrade gracefully if missing)
NEWSAPI_KEY=
X_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
